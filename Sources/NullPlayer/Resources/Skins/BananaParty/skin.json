{
    "meta": {
        "name": "BananaParty",
        "author": "NullPlayer",
        "version": "1.0",
        "description": "Outrageously yellow party skin with citrus glow, glossy banana tones, and mild translucent layering"
    },
    "palette": {
        "primary": "#fffb00",
        "secondary": "#ffd000",
        "accent": "#fff700",
        "highlight":"#e02256",
        "background": "#fff74d",
        "surface": "#ffe218",
        "text": "#e02256",
        "textDim": "#b86a44",
        "positive": "#d3ff2c",
        "negative": "#a74f00",
        "warning": "#ff9400",
        "border": "#e02256",
        "timeColor": "#e02256",
        "marqueeColor": "#e02256",
        "dataColor": "#e02256",
        "eqLow": "#dcff30",
        "eqMid": "#e02256",
        "eqHigh": "#ffb300"
    },
    "fonts": {
        "primaryName": "DepartureMono-Regular",
        "fallbackName": "Menlo",
        "titleSize": 9,
        "bodySize": 10,
        "smallSize": 7,
        "timeSize": 22,
        "infoSize": 6.5,
        "eqLabelSize": 7,
        "eqValueSize": 6,
        "marqueeSize": 12.5,
        "playlistSize": 8
    },
    "background": {
        "grid": {
            "color": "#fffbc0",
            "spacing": 28,
            "angle": 76,
            "opacity": 0.06,
            "perspective": false
        }
    },
    "glow": {
        "enabled": true,
        "radius": 14,
        "intensity": 0.58,
        "threshold": 0.6,
        "color": "#fff700",
        "elementBlur": 0.68
    },
    "window": {
        "borderWidth": 1.2,
        "borderColor": "#fffcd0",
        "cornerRadius": 12,
        "opacity": 0.8,
        "textOpacity": 0.9,
        "spectrumTransparentBackground": false,
        "waveformWindowOpacity": 0.8,
        "seamlessDocking": 1.0,
        "areaOpacity": {
            "mainWindow": {
                "background": 0.92,
                "border": 0.95,
                "content": 0.95
            },
            "timeDisplay": {
                "background": 0.9,
                "border": 0.93,
                "content": 0.95
            },
            "trackDisplay": {
                "background": 0.9,
                "border": 0.93,
                "content": 0.95
            },
            "volumeArea": {
                "background": 0.9,
                "border": 0.93,
                "content": 0.95
            },
            "spectrumArea": {
                "background": 0.5,
                "border": 0.93,
                "content": 0.95
            },
            "eqFaderBackground": {
                "background": 0.9,
                "border": 0.93,
                "content": 0.95
            },
            "curveBackground": {
                "background": 0.9,
                "border": 0.93,
                "content": 0.95
            }
        }
    },
    "marquee": {
        "scrollSpeed": 34,
        "scrollGap": 56
    },
    "elements": {
        "titlebar": {
            "color": "#ffda00"
        },
        "spectrum_titlebar": {
            "color": "#ffda00"
        },
        "playlist_titlebar": {
            "color": "#ffda00"
        },
        "eq_titlebar": {
            "color": "#ffda00"
        },
        "library_titlebar": {
            "color": "#ffda00"
        },
        "projectm_titlebar": {
            "color": "#ffda00"
        },
        "marquee_bg": {
            "color": "#ffe100"
        },
        "spectrum_area": {
            "color": "#fff800"
        },
        "playlist_text": {
            "color": "#e02256"
        },
        "tab_outline": {
            "color": "#e02256"
        },
        "tab_text": {
            "color": "#e02256"
        },
        "minicontrol_buttons": {
            "color": "#e02256"
        },
        "play_controls": {
            "color": "#e02256"
        },
        "seek_fill": {
            "color": "#e02256"
        },
        "volume_fill": {
            "color": "#e02256"
        },
        "info_cast": {
            "color": "#e02256"
        }
    },
    "animations": {
        "seek_fill": {
            "type": "glow",
            "duration": 1.8,
            "minValue": 0.65,
            "maxValue": 1.0
        }
    },
    "visualization": {
        "mainWindowMode": "vis_classic",
        "spectrumWindowMode": "vis_classic",
        "visClassic": {
            "mainWindowProfile": "Blue Flames",
            "spectrumWindowProfile": "Blue Flames",
            "mainWindowFitToWidth": true,
            "spectrumWindowFitToWidth": true
        },
        "fire": {
            "mainWindowStyle": "Inferno",
            "mainWindowIntensity": "Intense",
            "spectrumWindowStyle": "Inferno",
            "spectrumWindowIntensity": "Intense"
        },
        "lightning": {
            "mainWindowStyle": "Ember",
            "spectrumWindowStyle": "Ember"
        },
        "matrix": {
            "mainWindowColorScheme": "Amber",
            "mainWindowIntensity": "Intense",
            "spectrumWindowColorScheme": "Amber",
            "spectrumWindowIntensity": "Intense"
        }
    }
}
