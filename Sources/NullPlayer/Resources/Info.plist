<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Audio File</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.audio</string>
				<string>public.mp3</string>
				<string>public.mpeg-4-audio</string>
				<string>public.aiff-audio</string>
				<string>com.microsoft.waveform-audio</string>
				<string>org.xiph.flac</string>
				<string>org.xiph.ogg-vorbis</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>NullPlayer</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>com.nullplayer.app</string>
	<key>CFBundleName</key>
	<string>NullPlayer</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.28.2</string>
	<key>CFBundleVersion</key>
	<string>3</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.music</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- NSAllowsArbitraryLoads MUST be the only key here. On macOS 10.12+, pairing it
		     with a granular key (NSAllowsLocalNetworking / NSAllowsArbitraryLoadsForMedia /
		     NSAllowsArbitraryLoadsInWebContent) makes the system ignore NSAllowsArbitraryLoads
		     and block public cleartext http:// loads (-1022) — which broke http internet-radio
		     streams (issue #310). NSAllowsArbitraryLoads alone is a superset that also permits
		     local-network casting, so Sonos/Chromecast/DLNA are unaffected. -->
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSBonjourServices</key>
	<array>
		<string>_googlecast._tcp</string>
		<string>_airplay._tcp</string>
		<string>_raop._tcp</string>
		<string>_sonos._tcp</string>
	</array>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSLocalNetworkUsageDescription</key>
	<string>NullPlayer needs access to your local network to discover and cast audio to Chromecast, Sonos, and DLNA devices.</string>
</dict>
</plist>
